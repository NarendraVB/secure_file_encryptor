# ==========================================
# Python
# ==========================================
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# Virtual Environment
# ==========================================
venv/
.env/
.venv/

# ==========================================
# IDE
# ==========================================
.vscode/
.idea/

# ==========================================
# OS Files
# ==========================================
.DS_Store
Thumbs.db

# ==========================================
# Logs
# ==========================================
*.log

# ==========================================
# Generated Encryption Keys
# (Never commit real secret keys)
# ==========================================
keys/*
!keys/.gitkeep

# ==========================================
# Encrypted Output Files
# ==========================================
encrypted/*
!encrypted/.gitkeep

# ==========================================
# Test Cache
# ==========================================
.pytest_cache/
.coverage
htmlcov/

# ==========================================
# Build Artifacts
# ==========================================
build/
dist/
*.egg-info/